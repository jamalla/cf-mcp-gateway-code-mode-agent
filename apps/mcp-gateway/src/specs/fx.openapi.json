{
  "openapi": "3.1.0",
  "info": {
    "title": "FX Rates Tool API",
    "version": "1.0.0",
    "description": "Retrieves exchange rates and supported currencies for price normalization."
  },
  "servers": [
    {
      "url": "https://cf-tool-fx.example.workers.dev"
    }
  ],
  "paths": {
    "/rates": {
      "get": {
        "summary": "Get latest exchange rates",
        "operationId": "getRates",
        "parameters": [
          {
            "name": "base",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "EUR"
            }
          },
          {
            "name": "symbols",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Comma-separated currency codes, e.g. USD,MYR,SAR"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Rates retrieved successfully"
          }
        }
      }
    },
    "/currencies": {
      "get": {
        "summary": "List supported currencies",
        "operationId": "getCurrencies",
        "responses": {
          "200": {
            "description": "Currencies retrieved successfully"
          }
        }
      }
    }
  }
}
