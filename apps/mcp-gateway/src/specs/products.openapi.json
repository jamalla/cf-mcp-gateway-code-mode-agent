{
  "openapi": "3.1.0",
  "info": {
    "title": "Trending Products Tool API",
    "version": "1.0.0",
    "description": "Fetches public product data for demo e-commerce scenarios."
  },
  "servers": [
    {
      "url": "https://tool-products.example.workers.dev"
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "summary": "List products",
        "operationId": "listProducts",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Products retrieved successfully"
          }
        }
      }
    },
    "/products/categories": {
      "get": {
        "summary": "List categories",
        "operationId": "listCategories",
        "responses": {
          "200": {
            "description": "Categories retrieved successfully"
          }
        }
      }
    }
  }
}
