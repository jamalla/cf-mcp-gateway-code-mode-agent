{
  "openapi": "3.1.0",
  "info": {
    "title": "Cart Intelligence Tool API",
    "version": "1.0.0",
    "description": "Ranks candidate products into a shortlist using simple scoring logic."
  },
  "servers": [
    {
      "url": "https://cf-tool-cart-intel.to-jamz.workers.dev"
    }
  ],
  "paths": {
    "/analyze": {
      "post": {
        "summary": "Analyze and rank candidate products",
        "operationId": "analyzeProducts",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["targetCurrency", "products"],
                "properties": {
                  "targetCurrency": {
                    "type": "string"
                  },
                  "rates": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "number"
                    }
                  },
                  "preferences": {
                    "type": "object",
                    "properties": {
                      "prioritizeRating": {
                        "type": "boolean"
                      },
                      "prioritizeLowerPrice": {
                        "type": "boolean"
                      },
                      "inStockOnly": {
                        "type": "boolean"
                      },
                      "preferredCategory": {
                        "type": "string"
                      }
                    }
                  },
                  "products": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id", "title", "price"],
                      "properties": {
                        "id": {
                          "oneOf": [{ "type": "string" }, { "type": "number" }]
                        },
                        "title": {
                          "type": "string"
                        },
                        "category": {
                          "type": "string"
                        },
                        "price": {
                          "type": "number"
                        },
                        "currency": {
                          "type": "string"
                        },
                        "rating": {
                          "type": "number"
                        },
                        "stock": {
                          "type": "integer"
                        },
                        "brand": {
                          "type": "string"
                        },
                        "thumbnail": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analysis completed successfully"
          }
        }
      }
    }
  }
}
